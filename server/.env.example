NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/study_planner?retryWrites=true&w=majority
CORS_ORIGIN=https://autonomous-study-planner.vercel.app
FRONTEND_URL=https://autonomous-study-planner.vercel.app

JWT_ACCESS_SECRET=your_production_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_production_jwt_refresh_secret_key_here
JWT_EMAIL_VERIFICATION_SECRET=your_email_verification_secret_key_here
JWT_PASSWORD_RESET_SECRET=your_password_reset_secret_key_here

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@yourdomain.com
SMTP_PASS=smtp_password
SMTP_FROM_EMAIL=no-reply@study-pilot.com

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
